# -----------------------------------------------------------------------
# LangGraph Chatbot -- environment variables
# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.
# -----------------------------------------------------------------------

# -----------------------------------------------------------------------
# Ollama (default LLM + embedding runtime -- no key needed, runs locally)
# -----------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------
# Anthropic API (required when llm.provider = "anthropic")
# -----------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------
# Langfuse (self-hosted observability -- required when tracing.langfuse_enabled = true)
# Keys for the app process:
# -----------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=pk-lf-local-dev
LANGFUSE_SECRET_KEY=sk-lf-local-dev
LANGFUSE_HOST=http://localhost:3000
# Required for the Langfuse Docker container:
LANGFUSE_NEXTAUTH_SECRET=change-this-32-char-minimum-string
LANGFUSE_SALT=change-this-32-char-minimum-string
LANGFUSE_ADMIN_PASSWORD=changeme

# -----------------------------------------------------------------------
# Cloudflare (required when vectorstore.provider = "vectorize"
#             or embeddings.provider = "workers-ai")
# -----------------------------------------------------------------------
CF_ACCOUNT_ID=
CF_API_TOKEN=

# -----------------------------------------------------------------------
# n8n automation sidecar (required when using just dev-full)
# -----------------------------------------------------------------------
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-this-immediately
# Generate with: python -c "import secrets; print(secrets.token_hex(24))"
N8N_ENCRYPTION_KEY=replace-with-48-char-hex-string
N8N_BASE_URL=http://localhost:5678

# -----------------------------------------------------------------------
# Notion integration (required for /api/notion/sync endpoint)
# -----------------------------------------------------------------------
NOTION_TOKEN=secret_...
NOTION_DATABASE_ID=

# -----------------------------------------------------------------------
# Worklog assistant (optional -- worklog agent is disabled when WORKLOG_WORKER_URL is unset)
# -----------------------------------------------------------------------
WORKLOG_WORKER_URL=
WORKLOG_API_KEY=

# -----------------------------------------------------------------------
# EdgeNotes webhook (optional -- set to match LANGGRAPH_WEBHOOK_SECRET in EdgeNotes)
# -----------------------------------------------------------------------
LANGGRAPH_WEBHOOK_SECRET=
